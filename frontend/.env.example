# ── Production (Vercel) ──────────────────────────────────────────
# Set this to your Render backend URL in Vercel's Environment Variables UI
VITE_API_URL=https://nl-cad-backend.onrender.com

# ── Local development ────────────────────────────────────────────
# For local dev, leave VITE_API_URL empty (or omit it).
# Vite's proxy in vite.config.js forwards /api → http://localhost:8000 automatically.
# VITE_API_URL=
